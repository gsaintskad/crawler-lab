# Build from the monorepo root:
#   docker build -f apps/backend/Dockerfile -t crawler-lab/backend .

FROM node:20-alpine AS deps
RUN apk add --no-cache openssl
RUN corepack enable && corepack prepare pnpm@9.12.0 --activate
# Placeholder so `prisma generate` (run by db's prepare hook) can validate
# the schema during install. Real DATABASE_URL is provided at runtime.
ENV DATABASE_URL="postgresql://build:build@localhost:5432/build?schema=public"
WORKDIR /repo
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
# packages/db has a `prepare` hook that runs `prisma generate && tsc`,
# so its schema + source must exist before `pnpm install` runs.
COPY packages/db ./packages/db
COPY apps/backend/package.json ./apps/backend/
COPY apps/worker/package.json ./apps/worker/
COPY apps/frontend/package.json ./apps/frontend/
RUN pnpm install --frozen-lockfile

FROM deps AS build
COPY apps/backend ./apps/backend
RUN pnpm --filter @crawler-lab/backend build
# Prune dev deps in place. The Prisma client generated by db's prepare hook
# (under node_modules/.pnpm/@prisma+client@.../node_modules/.prisma/client)
# is preserved because @prisma/client is a runtime dep.
RUN pnpm install --frozen-lockfile --prod --ignore-scripts

FROM node:20-alpine AS runtime
RUN apk add --no-cache openssl
RUN addgroup -S app && adduser -S app -G app
ENV NODE_ENV=production
WORKDIR /app
COPY --from=build --chown=app:app /repo /app
USER app
EXPOSE 3000
WORKDIR /app/apps/backend
CMD ["node", "dist/main.js"]
